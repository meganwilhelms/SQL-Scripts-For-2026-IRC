  SELECT sch.transcript_div,   
         sch.id_num,   
         sch.yr_cde,   
         sch.trm_cde,   
         sm.x_listed_parnt_crs,   
         sch.crs_cde,   
         sch.transaction_sts,   
         sch.credit_hrs,   
         sch.repeat_flag,   
         sch.credit_type_cde,   
         sch.grade_cde,   
         sch.midtrm_credit_typ,   
         sch.midterm_gra_cde,   
         sch.absences,   
         sm.crs_cde,   
         sm.crs_title,   
         sm.crs_title_2,   
         sm.lead_instructr_id,   
         sm.crs_enrollment,   
         sm.current_reg_count,   
         sm.history_reg_count,   
         sm.wlisted_reg_count,   
         stdm.current_class_cde,   
         rc.clas_lst_incl_hold,   
         rc.clas_lst_sho_prfnm,   
         rc.clas_lst_incl_wlst,   
         rc.acad_credit_varies,   
         dd.acad_credit_label,   
         sm.x_listed_section,   
         sch.begin_dte,   
         sch.end_dte,   
         nfv.last_first_middle_suf,   
         nfv.preferred_name,   
         swhv.id_num  
    FROM TmsEPrd.dbo.name_format_view nfv LEFT OUTER JOIN TmsEPrd.dbo.students_with_holds_v swhv ON nfv.id_num = swhv.id_num,   
         TmsEPrd.dbo.student_crs_hist sch,   
         TmsEPrd.dbo.section_master sm,   
         TmsEPrd.dbo.student_master stdm,   
         TmsEPrd.dbo.division_def dd,   
         TmsEPrd.dbo.reg_config  rc
   WHERE ( stdm.id_num = sch.id_num ) and  
         ( sch.yr_cde = sm.yr_cde ) and  
         ( sch.trm_cde = sm.trm_cde ) and  
         ( sch.crs_cde = sm.crs_cde ) and  
         ( sm.division_cde = dd.div_cde ) and  
         ( nfv.id_num = stdm.id_num ) and  
         ( ( rc.reg_config_cde = '1'  ) AND  
         (sch.transaction_sts = 'C' OR  
         sch.transaction_sts = 'H' OR  
         (sch.transaction_sts = 'W' AND  
         rc.clas_lst_incl_wlst = 'Y')) AND  
         (rc.clas_lst_incl_hold = 'Y' OR  
         swhv.id_num is NULL) )    and sch.YR_CDE = 2025
